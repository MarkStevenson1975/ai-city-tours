{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "https://storiedtours.co.uk", "permanent": true }
  ],
  "rewrites": [
    { "source": "/:slug", "destination": "/tour" }
  ]
}
