# Copy to .env.local and fill in. Never commit .env.local to git.

# From Supabase project: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# From Supabase project: Project Settings → API → "anon public" key.
# This key is SAFE to ship to the browser — it relies on Row-Level Security
# for protection, NOT secrecy. Do NOT use the service-role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key (Project Settings → API → service_role). SERVER ONLY.
# Used by admin operations and the Stripe webhook to bypass RLS. Never ships
# to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Public URL of the dashboard app (used for auth + Stripe redirect URLs).
DASHBOARD_URL=https://storied-dashboard.vercel.app

# ---- Stripe (self-serve subscriptions) ----
# Secret key: Stripe Dashboard → Developers → API keys. SERVER ONLY.
STRIPE_SECRET_KEY=sk_live_or_test_...

# Webhook signing secret for the /api/stripe/webhook endpoint.
# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for each plan + interval (Stripe → Products → Pricing).
# Create three products (Trail, Town, Destination), each with a monthly and
# an annual recurring price, then paste the price IDs (price_...) here.
STRIPE_PRICE_TRAIL_MONTHLY=price_...
STRIPE_PRICE_TRAIL_ANNUAL=price_...
STRIPE_PRICE_TOWN_MONTHLY=price_...
STRIPE_PRICE_TOWN_ANNUAL=price_...
STRIPE_PRICE_DESTINATION_MONTHLY=price_...
STRIPE_PRICE_DESTINATION_ANNUAL=price_...

# ---- Operator feedback widget ----
# Make webhook that receives feedback submissions and emails them to
# team@thesetupcrew.co.uk. Create a "Custom webhook" trigger in Make, copy its
# URL here. The CLAUDE_API_KEY above powers the feedback chat + summary.
MAKE_FEEDBACK_WEBHOOK_URL=https://hook.eu2.make.com/your-webhook-id
